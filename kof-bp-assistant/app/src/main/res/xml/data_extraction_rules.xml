<?xml version="1.0" encoding="utf-8"?>
<!--
  数据提取规则（Android 12+）。
  本 App 存储本地数据包、坐标配置和权限状态，不参与云备份与设备迁移，
  全部排除，避免旧数据在新设备上还原后与服务端版本不一致。
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>
